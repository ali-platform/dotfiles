#!/usr/bin/env bash
set -e

# Parse command line arguments
BRANCH_NAME=""
ALL_REMOTE_BRANCHES=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -a|--all)
            ALL_REMOTE_BRANCHES=true
            shift
            ;;
        *)
            BRANCH_NAME="$1"
            shift
            ;;
    esac
done

# Function to get current branch
get_current_branch() {
    git rev-parse --abbrev-ref HEAD
}

# Function to check if working tree is clean
is_working_tree_clean() {
    git diff-index --quiet HEAD -- 2>/dev/null
}

# Function to check for untracked files
has_untracked_files() {
    [[ -n $(git ls-files --others --exclude-standard) ]]
}

# Function to get commits ahead of remote
get_commits_ahead() {
    local branch="$1"
    git rev-list --count "@{u}..HEAD" 2>/dev/null || echo "0"
}

# Function to get commits behind remote
get_commits_behind() {
    local branch="$1"
    git rev-list --count "HEAD..@{u}" 2>/dev/null || echo "0"
}

# Function to merge from a git branch
merge_from_git_branch() {
    local branch_name="$1"
    local original_branch=$(get_current_branch)

    # Check for potential merge conflicts
    local merge_base=$(git merge-base FETCH_HEAD "$branch_name")
    local merge_results=$(git merge-tree "$merge_base" "$branch_name" FETCH_HEAD 2>/dev/null || echo "")

    if echo "$merge_results" | grep -q '^+<* \.our$'; then
        echo -e "\033[0;33mWarning: There are merge conflicts merging $branch_name to $original_branch\033[0m" >&2
        exit 1
    fi

    local message="Merging $branch_name to $original_branch"
    echo -e "\033[0;32m$message\033[0m"
    git merge "$branch_name" -m "$message"

    local commits_ahead=$(get_commits_ahead "$original_branch")
    if [[ "$commits_ahead" -gt 0 ]]; then
        echo -e "\033[0;32mPushing merge changes to origin/$original_branch\033[0m"
        git push
    fi
}

# Fetch from origin
git fetch && git fetch origin

original_branch=$(get_current_branch)

# Check for uncommitted changes
if ! is_working_tree_clean || has_untracked_files; then
    echo -e "\033[0;33mWarning: There are uncommitted changes in $original_branch\033[0m" >&2
    exit 1
fi

# Pull if behind
commits_behind=$(get_commits_behind "$original_branch")
if [[ "$commits_behind" -gt 0 ]]; then
    echo -e "\033[0;32mPulling upstream changes to $original_branch\033[0m"
    git pull
fi

# Push if ahead
commits_ahead=$(get_commits_ahead "$original_branch")
if [[ "$commits_ahead" -gt 0 ]]; then
    echo -e "\033[0;32mPushing changes to origin/$original_branch\033[0m"
    git push
fi

# Get remote branches
remote_branches=$(git branch --remotes --list --format='%(refname:short)' | grep '^origin/' | sed 's|^origin/||')

# Determine which branches to process
if [[ "$ALL_REMOTE_BRANCHES" == "true" ]]; then
    branches=$(echo "$remote_branches" | grep -v "^${original_branch}$")
else
    if [[ -z "$BRANCH_NAME" ]]; then
        echo "Error: Please specify branch name(s) or use --all flag" >&2
        echo "Usage: $0 [branch1,branch2,...] or $0 --all" >&2
        exit 1
    fi

    # Split comma-separated branches
    IFS=',' read -ra branch_array <<< "$BRANCH_NAME"
    branches=""

    # Verify that all specified branches exist
    for branch in "${branch_array[@]}"; do
        branch=$(echo "$branch" | xargs)  # trim whitespace
        if ! echo "$remote_branches" | grep -q "^${branch}$"; then
            echo -e "\033[0;33mWarning: Branch $branch does not exist\033[0m" >&2
            exit 1
        fi
        branches+="$branch"$'\n'
    done
    branches=$(echo "$branches" | head -n -1)  # remove trailing newline
fi

merge_from_branch="$original_branch"

# Process each branch
while IFS= read -r branch_name; do
    [[ -z "$branch_name" ]] && continue

    echo -e "\033[0;36m=====================================\033[0m"
    echo -e "\033[0;36mStart processing branch $branch_name\033[0m"

    git checkout "$branch_name"

    # Check for uncommitted changes
    if ! is_working_tree_clean || has_untracked_files; then
        echo -e "\033[0;33mWarning: There are uncommitted changes in $branch_name\033[0m" >&2
        exit 1
    fi

    # Pull if behind
    commits_behind=$(get_commits_behind "$branch_name")
    if [[ "$commits_behind" -gt 0 ]]; then
        echo -e "\033[0;32mPulling upstream changes to $branch_name\033[0m"
        git pull
    fi

    # Push if ahead
    commits_ahead=$(get_commits_ahead "$branch_name")
    if [[ "$commits_ahead" -gt 0 ]]; then
        echo -e "\033[0;32mPushing changes to origin/$branch_name\033[0m"
        git push
    fi

    merge_from_git_branch "$merge_from_branch"
    merge_from_branch="$branch_name"

    echo -e "\033[0;36m=====================================\033[0m"
    echo ""
done <<< "$branches"

echo -e "\033[0;36mChecking out original branch $original_branch\033[0m"
git checkout "$original_branch"
echo -e "\033[0;36mCompleted processing branches\033[0m"

