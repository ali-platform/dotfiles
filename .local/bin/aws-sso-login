#!/bin/env bash
# This script is designed to sourced from your shell to set the AWS_PROFILE variable

# Determine which config file to use
if [ -f .ali/projectInfo.json ]; then
    CONFIG_FILE=.ali/projectInfo.json
elif [ -f bootstrap.json ]; then
    CONFIG_FILE=bootstrap.json
else
    CONFIG_FILE=""
fi

# Get current git branch
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

# Initialize variables
STACK=""
export AWS_PROFILE=""

# Handle argument vs branch-based lookup
if [ $# -gt 0 ]; then
    # Argument provided - use it as AWS_PROFILE, but try to find STACK from config
    LOOKUP_KEY="$1"

    if [ "$CONFIG_FILE" = ".ali/projectInfo.json" ] && [ -n "$LOOKUP_KEY" ]; then
        # Try to match by stackName first, get the values directly
        STACK=$(jq -r '.stacks[] | select(.stackName == "'"$LOOKUP_KEY"'") | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        AWS_PROFILE=$(jq -r '.stacks[] | select(.stackName == "'"$LOOKUP_KEY"'") | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)

        # If no match, try to match by accountName
        if [ -z "$AWS_PROFILE" ]; then
            STACK=$(jq -r '.stacks[] | select(.accountName == "'"$LOOKUP_KEY"'") | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
            AWS_PROFILE=$(jq -r '.stacks[] | select(.accountName == "'"$LOOKUP_KEY"'") | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        fi
    fi

    # If no match found in config, use the argument as AWS_PROFILE
    if [ -z "$AWS_PROFILE" ]; then
        AWS_PROFILE="$1"
    fi
else
    # No argument - use branch name for smart lookup
    LOOKUP_KEY="$BRANCH_NAME"

    if [ "$CONFIG_FILE" = ".ali/projectInfo.json" ] && [ -n "$LOOKUP_KEY" ]; then
        # Try to match by stackName first, get the values directly
        STACK=$(jq -r '.stacks[] | select(.stackName == "'"$LOOKUP_KEY"'") | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        AWS_PROFILE=$(jq -r '.stacks[] | select(.stackName == "'"$LOOKUP_KEY"'") | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)

        # If no match, try to match by accountName
        if [ -z "$AWS_PROFILE" ]; then
            STACK=$(jq -r '.stacks[] | select(.accountName == "'"$LOOKUP_KEY"'") | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
            AWS_PROFILE=$(jq -r '.stacks[] | select(.accountName == "'"$LOOKUP_KEY"'") | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        fi

        # If no match, try to match by branchName
        if [ -z "$AWS_PROFILE" ]; then
            STACK=$(jq -r '.stacks[] | select(.branchName == "'"$LOOKUP_KEY"'") | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
            AWS_PROFILE=$(jq -r '.stacks[] | select(.branchName == "'"$LOOKUP_KEY"'") | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        fi
    fi

    # If still no match, fall back to workingStack or other defaults
    if [ -z "$AWS_PROFILE" ]; then
        if [ "$CONFIG_FILE" = ".ali/projectInfo.json" ]; then
            # Use workingStack from projectInfo.json
            STACK=$(jq -r '.stacks[] | select(.workingStack == true) | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
            AWS_PROFILE=$(jq -r '.stacks[] | select(.workingStack == true) | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        elif [ "$CONFIG_FILE" = "bootstrap.json" ]; then
            # Use workingStack from bootstrap.json (legacy support)
            STACK=$(jq -r '.stacks[] | select(.workingStack == true) | .stackName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
            AWS_PROFILE=$(jq -r '.stacks[] | select(.workingStack == true) | .accountName' < "$CONFIG_FILE" 2>/dev/null | head -n 1)
        else
            # No config file found, use default
            AWS_PROFILE="ali-shared"
        fi
    fi

    # Final fallback to ali-shared if no stack entry was found
    if [ -z "$AWS_PROFILE" ]; then
        AWS_PROFILE="ali-shared"
    fi
fi

# Verify that AWS_PROFILE exists in ~/.aws/config
if ! grep -q "\[profile $AWS_PROFILE\]" ~/.aws/config; then
  echo -e "\033[0;31mAWS_PROFILE $AWS_PROFILE not found in ~/.aws/config\033[0m"
  exit 1
fi

echo -e "\033[0;36mUsing AWS account $AWS_PROFILE\033[0m"
MIN_LEFT=30

# Pick date command (gdate on macOS with coreutils)
DATEBIN="date"
if command -v gdate >/dev/null 2>&1; then DATEBIN="gdate"; fi

EXP_JSON="$(aws configure export-credentials --profile "$AWS_PROFILE" --format process 2>/dev/null || true)"
EXP_ISO="$(printf '%s' "$EXP_JSON" | jq -r '.Expiration // empty')"

REMAIN_SECS=-1
if [ -n "$EXP_ISO" ]; then
    EXP_EPOCH="$("$DATEBIN" -u -d "$EXP_ISO" +%s 2>/dev/null || true)"
    if [ -n "$EXP_EPOCH" ]; then
        NOW_EPOCH="$("$DATEBIN" -u +%s)"
        REMAIN_SECS=$(( EXP_EPOCH - NOW_EPOCH ))
    fi
fi

REQUIRED_SECS=$(( MIN_LEFT * 60 ))
NEED_LOGIN=0
IS_SSO_PROFILE=0

SSO_START_URL="$(aws configure get sso_start_url --profile "$AWS_PROFILE" 2>/dev/null || true)"
SSO_SESSION_NAME="$(aws configure get sso_session --profile "$AWS_PROFILE" 2>/dev/null || true)"
if [ -n "$SSO_START_URL" ] || [ -n "$SSO_SESSION_NAME" ]; then
    IS_SSO_PROFILE=1
fi

# Soft expiration check
if (( REMAIN_SECS < REQUIRED_SECS )); then
    NEED_LOGIN=1
fi

# Hard validity check (authoritative)
if ! aws sts get-caller-identity --profile "$AWS_PROFILE" --output json >/dev/null 2>&1; then
    NEED_LOGIN=1
fi

# Additional SSO access-token check (catches cases where role creds look valid but SSO token is invalid)
if (( IS_SSO_PROFILE == 1 )); then
    if ! aws sso list-accounts --profile "$AWS_PROFILE" --max-results 1 --output json >/dev/null 2>&1; then
        NEED_LOGIN=1
    fi
fi

if (( NEED_LOGIN == 0 )); then
    REMAIN_MIN=$(( REMAIN_SECS / 60 ))
    echo "OK: ${REMAIN_MIN} minutes left (expires at ${EXP_ISO})."
else
    if (( REMAIN_SECS > 0 )); then
        REMAIN_MIN=$(( REMAIN_SECS / 60 ))
        echo "NOT OK: only ${REMAIN_MIN} minutes left (expires at ${EXP_ISO})." >&2
    else
        echo "NOT OK: credentials missing/expired/invalid (expires at ${EXP_ISO:-unknown})." >&2
    fi
    echo -e "\033[0;36mAuthenticating with SSO\033[0m"
    aws sso login --profile "$AWS_PROFILE"
fi

CLUSTER=$(aws eks list-clusters --query clusters[0] --output text)
if [[ "$CLUSTER" != "None" ]]
then
    echo -e "\033[0;36mAuthenticating to the $CLUSTER kubernetes cluster\033[0m"
    aws eks update-kubeconfig --region us-east-2 --name $CLUSTER --alias $CLUSTER
fi

# Select Pulumi stack if a stack-specific config file exists
if [ -z "$STACK" ]; then
    STACK=$AWS_PROFILE
fi

if [ -f "Pulumi.$STACK.yaml" ]; then
    echo -e "\033[0;36mSelecting the $STACK pulumi stack\033[0m"
    pulumi stack select $STACK
fi
