#!/usr/bin/env bash
set -e

# Parse command line arguments
BRANCH_NAME="$1"

if [[ -z "$BRANCH_NAME" ]]; then
    echo "Error: Please specify a branch name" >&2
    echo "Usage: $0 <branch-name>" >&2
    exit 1
fi

# Function to get current branch
get_current_branch() {
    git rev-parse --abbrev-ref HEAD
}

# Function to check if working tree is clean
is_working_tree_clean() {
    git diff-index --quiet HEAD -- 2>/dev/null
}

# Function to check for untracked files
has_untracked_files() {
    [[ -n $(git ls-files --others --exclude-standard) ]]
}

# Function to get commits ahead of remote
get_commits_ahead() {
    git rev-list --count "@{u}..HEAD" 2>/dev/null || echo "0"
}

# Function to get commits behind remote
get_commits_behind() {
    git rev-list --count "HEAD..@{u}" 2>/dev/null || echo "0"
}

# Function to unblock GitHub branch
unblock_github_branch() {
    local branch_name="$1"

    # Parse owner and repo from git remote URL
    local remote_url=$(git remote get-url origin)
    local owner repo

    if [[ "$remote_url" =~ ([^/:]+)/([^/\.]+)(\.git)?$ ]]; then
        owner="${BASH_REMATCH[1]}"
        repo="${BASH_REMATCH[2]}"
    else
        echo "Error: Could not parse git remote URL" >&2
        return 1
    fi

    local token=$(gh auth token)

    # Check if branch is protected
    local branches=$(curl -s -H "Authorization: token $token" \
        "https://api.github.com/repos/$owner/$repo/branches")

    local is_protected=$(echo "$branches" | jq -r --arg branch "$branch_name" \
        '.[] | select(.name == $branch and .protected == true) | .protected')

    if [[ "$is_protected" == "true" ]]; then
        echo "Opening $branch_name branch for $owner/$repo"

        local protection='{
            "restrictions": {
                "users": [],
                "teams": [],
                "apps": []
            },
            "required_pull_request_reviews": {
                "dismiss_stale_reviews": true,
                "require_code_owner_reviews": true,
                "dismissal_restrictions": {
                    "users": [],
                    "teams": []
                }
            },
            "enforce_admins": false,
            "required_status_checks": null
        }'

        curl -s -H "Authorization: token $token" \
            -H "Content-Type: application/json" \
            -X PUT \
            -d "$protection" \
            "https://api.github.com/repos/$owner/$repo/branches/$branch_name/protection" > /dev/null
    fi
}

# Function to merge git branch
merge_git_branch() {
    local branch_name="$1"
    local current_branch=$(get_current_branch)

    # Check for potential merge conflicts
    local merge_base=$(git merge-base FETCH_HEAD "$branch_name")
    local merge_results=$(git merge-tree "$merge_base" "$branch_name" FETCH_HEAD 2>/dev/null || echo "")

    if echo "$merge_results" | grep -q '^+<* \.our$'; then
        echo -e "\033[0;33mWarning: There are merge conflicts merging $branch_name to $current_branch\033[0m" >&2
        exit 1
    fi

    local message="Merging $branch_name to $current_branch"
    echo -e "\033[0;32m$message\033[0m"
    git merge "$branch_name" -m "$message"

    local commits_ahead=$(get_commits_ahead)
    if [[ "$commits_ahead" -gt 0 ]]; then
        echo -e "\033[0;32mPushing merge changes to origin/$current_branch\033[0m"
        git push
    fi
}

# Fetch from origin
git fetch && git fetch origin

current_branch=$(get_current_branch)

# Check for uncommitted changes
if ! is_working_tree_clean || has_untracked_files; then
    echo -e "\033[0;33mWarning: There are uncommitted changes in $current_branch\033[0m" >&2
    exit 1
fi

# Pull if behind
commits_behind=$(get_commits_behind)
if [[ "$commits_behind" -gt 0 ]]; then
    echo -e "\033[0;32mPulling upstream changes to $current_branch\033[0m"
    git pull
fi

# Push if ahead
commits_ahead=$(get_commits_ahead)
if [[ "$commits_ahead" -gt 0 ]]; then
    echo -e "\033[0;32mPushing changes to origin/$current_branch\033[0m"
    git push
fi

# Get remote branches
remote_branches=$(git branch --remotes --list --format='%(refname:short)' | grep '^origin/' | sed 's|^origin/||')

# Verify that the specified branch exists
if ! echo "$remote_branches" | grep -q "^${BRANCH_NAME}$"; then
    echo -e "\033[0;33mWarning: Branch $BRANCH_NAME does not exist\033[0m" >&2
    exit 1
fi

# Checkout the target branch
git checkout "$BRANCH_NAME"

# Check for uncommitted changes
if ! is_working_tree_clean || has_untracked_files; then
    echo -e "\033[0;33mWarning: There are uncommitted changes in $BRANCH_NAME\033[0m" >&2
    exit 1
fi

# Pull if behind
commits_behind=$(get_commits_behind)
if [[ "$commits_behind" -gt 0 ]]; then
    echo -e "\033[0;32mPulling upstream changes to $BRANCH_NAME\033[0m"
    git pull
fi

# Checkout back to original branch
git checkout "$current_branch"

# Merge the target branch into current
merge_git_branch "$BRANCH_NAME"

# Push if behind
commits_behind=$(get_commits_behind)
if [[ "$commits_behind" -gt 0 ]]; then
    echo -e "\033[0;32mPushing changes to origin/$BRANCH_NAME\033[0m"
    git push
fi


