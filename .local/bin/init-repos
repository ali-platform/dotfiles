#!/usr/bin/env bash
set -e

# Parse command line arguments
REFRESH=false
AUTO_FIX=false
while [[ $# -gt 0 ]]; do
    case $1 in
        -r|--refresh)
            REFRESH=true
            shift
            ;;
        --auto-fix)
            AUTO_FIX=true
            shift
            ;;
        *)
            echo "Unknown option: $1"
            echo "Usage: $0 [-r|--refresh] [--auto-fix]"
            exit 1
            ;;
    esac
done

# Auto-fix repository state so normal fetch/pull operations get complete refs/history.
AutoFixExistingRepo() {
    local repo_name="$1"

    # Ensure all branch refs are fetched, not just a single branch.
    git config --replace-all remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

    # Convert shallow clones to full history.
    if [[ "$(git rev-parse --is-shallow-repository 2>/dev/null || echo false)" == "true" ]]; then
        echo -e "\033[0;36mRepairing shallow history for $repo_name\033[0m" >&2
        git fetch --unshallow origin || git fetch --depth=2147483647 origin
    fi

    # Refresh refs and tags now that refspec is complete.
    git fetch origin --prune --tags

    # Ensure current branch tracks a valid upstream.
    local current_branch
    current_branch=$(git branch --show-current)
    if [[ -z "$current_branch" ]]; then
        return
    fi

    local upstream
    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
    if [[ -n "$upstream" ]] && git show-ref --verify --quiet "refs/remotes/$upstream"; then
        return
    fi

    local target_upstream=""
    if git show-ref --verify --quiet "refs/remotes/origin/$current_branch"; then
        target_upstream="origin/$current_branch"
    else
        local remote_head
        remote_head=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
        if [[ -n "$remote_head" ]] && git show-ref --verify --quiet "refs/remotes/$remote_head"; then
            target_upstream="$remote_head"
        fi
    fi

    if [[ -n "$target_upstream" ]]; then
        echo -e "\033[0;36mSetting upstream for $repo_name: $current_branch -> $target_upstream\033[0m" >&2
        git branch --set-upstream-to="$target_upstream" "$current_branch" > /dev/null
    else
        echo -e "\033[0;33mUnable to auto-fix upstream for $repo_name: no suitable origin branch found\033[0m" >&2
    fi
}

# Update repository safely without failing the whole run on branch tracking issues.
RefreshExistingRepo() {
    local repo_name="$1"

    # Keep refs current before deciding whether pull is possible.
    git fetch origin --prune --tags

    local upstream
    upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
    if [[ -z "$upstream" ]]; then
        echo -e "\033[0;33mSkipping pull for $repo_name: current branch has no upstream\033[0m" >&2
        return
    fi

    if ! git show-ref --verify --quiet "refs/remotes/$upstream"; then
        echo -e "\033[0;33mSkipping pull for $repo_name: upstream $upstream is missing on remote\033[0m" >&2
        return
    fi

    if ! git pull --ff-only; then
        echo -e "\033[0;33mSkipping pull for $repo_name: unable to fast-forward\033[0m" >&2
    fi
}

# Function to clone repositories
CloneRepos() {
    local folder="$1"
    local repos_json="$2"
    local refresh="$3"
    local auto_fix="$4"

    local folder_list=(
        "action"
        "aws-account"
        "cloud-engineering"
        "container"
        "github"
        "ss-github"
        "kubernetes"
        "packer"
        "php-lib"
        "platform"
        "pulumi"
        "repository-template"
        "workflow"
    )

    if [[ -z "$repos_json" ]]; then
        return
    fi

    # Skip if input is not valid JSON array.
    if ! echo "$repos_json" | jq -e 'type == "array"' > /dev/null 2>&1; then
        echo -e "\033[0;33mSkipping invalid repository payload for $folder\033[0m" >&2
        return
    fi

    echo "$repos_json" | jq -c '.[]' | while read -r repo; do
        local repo_name=$(echo "$repo" | jq -r '.name')
        local ssh_url=$(echo "$repo" | jq -r '.sshUrl')

        # Find matching subfolder
        local sub_folder=""
        for prefix in "${folder_list[@]}"; do
            if [[ "$repo_name" == "$prefix"* ]]; then
                sub_folder="$prefix"
                break
            fi
        done

        # Create directory path
        local path="$HOME/src/$folder"
        if [[ -n "$sub_folder" ]]; then
            path="$path/$sub_folder"
        fi
        mkdir -p "$path"

        path="$path/$repo_name"

        # Clone or update repository
        if [[ ! -d "$path" ]]; then
            echo -e "\033[0;36mCloning $ssh_url\033[0m" >&2
            # Prefer partial clone to keep initial download smaller without losing refs.
            if ! git clone --filter=blob:none "$ssh_url" "$path"; then
                echo -e "\033[0;33mPartial clone unsupported, falling back to full clone for $repo_name\033[0m" >&2
                git clone "$ssh_url" "$path"
            fi
        else
            if [[ "$auto_fix" == "true" ]]; then
                pushd "$path" > /dev/null
                AutoFixExistingRepo "$repo_name"
                popd > /dev/null
            fi

            if [[ "$refresh" == "true" ]]; then
                echo -e "\033[0;36mUpdating $repo_name\033[0m" >&2
                pushd "$path" > /dev/null
                RefreshExistingRepo "$repo_name"
                popd > /dev/null
            fi
        fi

        # Build tags array
        local tags
        if [[ -n "$sub_folder" ]]; then
            tags="[\"$folder/$sub_folder\"]"
        else
            tags="[\"$folder\"]"
        fi

        # Output project item JSON
        jq -n \
            --arg name "$repo_name" \
            --arg rootPath "vscode-remote://wsl+${WSL_DISTRO_NAME}/$path" \
            --argjson tags "$tags" \
            '{name: $name, rootPath: $rootPath, tags: $tags, enabled: true}'
    done
}

# Function to clone organization repositories
CloneOrgRepos() {
    local org="$1"
    local refresh="$2"
    local auto_fix="$3"

    echo -e "\033[0;32mProcessing organization: $org\033[0m" >&2

    local repos
    if ! repos=$(gh repo list "$org" --no-archived --json "name,sshUrl" --limit 500); then
        echo -e "\033[0;33mUnable to list repos for $org; skipping\033[0m" >&2
        return
    fi

    # Filter studysocial repos
    if [[ "$org" == "studysocial" ]]; then
        if ! repos=$(echo "$repos" | jq '[.[] | select(.name | test("^(ss|platform|container|github)") or test("lambda"))]'); then
            echo -e "\033[0;33mUnable to filter repos for $org; skipping\033[0m" >&2
            return
        fi
    fi

    CloneRepos "$org" "$repos" "$refresh" "$auto_fix"
}

# Get GitHub profile
if [[ -f "$HOME/.config/gh/hosts.yml" ]]; then
    github_profile=$(grep -A 1 "github.com:" "$HOME/.config/gh/hosts.yml" | grep "user:" | awk '{print $2}')
else
    echo "Unable to locate GitHub user profile name, try gh auth login"
    exit 1
fi

# Initialize project items array
project_items_file=$(mktemp)

# Clone all organization repos
CloneOrgRepos "AccelerateLearning" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-back-office" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-data-gov" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-marketing" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-one-platform" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-onramp" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-open" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "ali-platform" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "stemscopes-v3" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "stemscopes-v4" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"
CloneOrgRepos "studysocial" "$REFRESH" "$AUTO_FIX" >> "$project_items_file"

# Create project manager file
pm_path="$USERPROFILE/AppData/Roaming/Code/User/globalStorage/alefragnani.project-manager"
mkdir -p "$pm_path"

# Combine all project items into a JSON array
jq -s '.' "$project_items_file" > "$pm_path/projects.json"

# Cleanup
rm "$project_items_file"

echo -e "\033[0;32mDone! Project list saved to $pm_path/projects.json\033[0m"
