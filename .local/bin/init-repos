#!/usr/bin/env bash
set -e

# Parse command line arguments
REFRESH=false
while [[ $# -gt 0 ]]; do
    case $1 in
        -r|--refresh)
            REFRESH=true
            shift
            ;;
        *)
            echo "Unknown option: $1"
            echo "Usage: $0 [-r|--refresh]"
            exit 1
            ;;
    esac
done

# Function to clone repositories
CloneRepos() {
    local folder="$1"
    local repos_json="$2"
    local refresh="$3"

    local folder_list=(
        "action"
        "aws-account"
        "cloud-engineering"
        "container"
        "github"
        "ss-github"
        "kubernetes"
        "packer"
        "php-lib"
        "platform"
        "pulumi"
        "repository-template"
        "workflow"
    )

    if [[ -z "$repos_json" ]]; then
        return
    fi

    # Skip if input is not valid JSON array.
    if ! echo "$repos_json" | jq -e 'type == "array"' > /dev/null 2>&1; then
        echo -e "\033[0;33mSkipping invalid repository payload for $folder\033[0m" >&2
        return
    fi

    echo "$repos_json" | jq -c '.[]' | while read -r repo; do
        local repo_name=$(echo "$repo" | jq -r '.name')
        local ssh_url=$(echo "$repo" | jq -r '.sshUrl')

        # Find matching subfolder
        local sub_folder=""
        for prefix in "${folder_list[@]}"; do
            if [[ "$repo_name" == "$prefix"* ]]; then
                sub_folder="$prefix"
                break
            fi
        done

        # Create directory path
        local path="$HOME/src/$folder"
        if [[ -n "$sub_folder" ]]; then
            path="$path/$sub_folder"
        fi
        mkdir -p "$path"

        path="$path/$repo_name"

        # Clone or update repository
        if [[ ! -d "$path" ]]; then
            echo -e "\033[0;36mCloning $ssh_url\033[0m" >&2
            git clone --depth 1 "$ssh_url" "$path"
        else
            if [[ "$refresh" == "true" ]]; then
                echo -e "\033[0;36mUpdating $repo_name\033[0m" >&2
                pushd "$path" > /dev/null
                git pull
                popd > /dev/null
            fi
        fi

        # Build tags array
        local tags
        if [[ -n "$sub_folder" ]]; then
            tags="[\"$folder/$sub_folder\"]"
        else
            tags="[\"$folder\"]"
        fi

        # Output project item JSON
        jq -n \
            --arg name "$repo_name" \
            --arg rootPath "file://$path" \
            --argjson tags "$tags" \
            '{name: $name, rootPath: $rootPath, tags: $tags, enabled: true}'
    done
}

# Function to clone organization repositories
CloneOrgRepos() {
    local org="$1"
    local refresh="$2"

    echo -e "\033[0;32mProcessing organization: $org\033[0m" >&2

    local repos
    if ! repos=$(gh repo list "$org" --no-archived --json "name,sshUrl" --limit 500); then
        echo -e "\033[0;33mUnable to list repos for $org; skipping\033[0m" >&2
        return
    fi

    # Filter studysocial repos
    if [[ "$org" == "studysocial" ]]; then
        if ! repos=$(echo "$repos" | jq '[.[] | select(.name | test("^(ss|platform|container|github)") or test("lambda"))]'); then
            echo -e "\033[0;33mUnable to filter repos for $org; skipping\033[0m" >&2
            return
        fi
    fi

    CloneRepos "$org" "$repos" "$refresh"
}

# Get GitHub profile
if [[ -f "$HOME/.config/gh/hosts.yml" ]]; then
    github_profile=$(grep -A 1 "github.com:" "$HOME/.config/gh/hosts.yml" | grep "user:" | awk '{print $2}')
else
    echo "Unable to locate GitHub user profile name, try gh auth login"
    exit 1
fi

# Initialize project items array
project_items_file=$(mktemp)

# Clone all organization repos
CloneOrgRepos "AccelerateLearning" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-back-office" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-data-gov" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-marketing" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-one-platform" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-onramp" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-open" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "ali-platform" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "stemscopes-v3" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "stemscopes-v4" "$REFRESH" >> "$project_items_file"
CloneOrgRepos "studysocial" "$REFRESH" >> "$project_items_file"

# Create project manager file
pm_path="$HOME/.config/Code/User/globalStorage/alefragnani.project-manager"
mkdir -p "$pm_path"

# Combine all project items into a JSON array
jq -s '.' "$project_items_file" > "$pm_path/projects.json"

# Cleanup
rm "$project_items_file"

echo -e "\033[0;32mDone! Project list saved to $pm_path/projects.json\033[0m"
